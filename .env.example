# ayaka-hand — environment template.
# Copy this file to `.env` (in the repo root) and fill in real values.
# `.env` is gitignored — NEVER commit your real keys.

# Required only for the inference server's Cortex "second opinion" (factory/serve).
# Get one at https://openrouter.ai/  — used to call Qwen3-VL-32B-Instruct.
OPENROUTER_API_KEY=

# Optional: alternative VLM provider used during some labeling runs.
FIREWORKS_API_KEY=
