# pixels locally with factory/labeling/harvest_coco.py.
data/ayaka-crops/crops/

# OS
.DS_Store
Thumbs.db

# NOTE: the bundled model/runtime binaries under web/public/models/ and
# web/public/ort/ are intentionally committed so a fresh clone runs offline.
